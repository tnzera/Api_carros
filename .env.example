# Banco de dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=sua_senha
DB_NAME=locacao_carros

# Autenticação JWT
JWT_SECRET=troque-por-uma-chave
JWT_EXPIRES_IN=1d

# Admin padrão criado automaticamente quando o banco não possui nenhum admin
# (opcional — sem estas variáveis, usa admin@locadora.com / admin123)
# ADMIN_EMAIL=admin@locadora.com
# ADMIN_PASSWORD=admin123

# Origem do front-end
# FRONTEND_URL=https://seu-front.com
